{
  "name": "pure-dango",
  "version": "0.9.2",
  "type": "module",
  "sourceType": "module",
  "description": "A simple programming language built in JavaScript",
  "bin": {
    "pure-dango": "src/index.js"
  },
  "scripts": {
    "build": "node src/scripts/build.js"
  },
  "dependencies": {
    "decimal.js": "^10.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "src/scripts/launcher.cjs"
    ],
    "assets": [
      "package.json",
      "node_modules/**/*",
      "src/index.ts",
      "src/core/**/*.js",
      "src/runtime/**/*.js"
    ],
    "targets": [
      "node18-win-x64"
    ]
  }
}
