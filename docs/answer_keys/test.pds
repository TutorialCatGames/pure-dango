function selectionSort(arr)
{
	for (new i = 0; i < len(arr); i++)
	{
		new lowest = i;
		for (new j = i + 1; j < len(arr); j++)
		{
			if (arr[lowest] > arr[j]) lowest = j;
		}

		if (i != lowest)
		{
			# swap the elements
			new saved   = arr[i];
			arr[i]      = arr[lowest];
			arr[lowest] = saved;
		}
	}

	return arr;
} 
print(selectionSort([27, 3, 7, 1, 0]));

