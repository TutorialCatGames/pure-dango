{
    "name": "pure-dango",
    "version": "1.8.5",
    "type": "module",
    "description": "A simple programming language built in JavaScript",
    "license": "MIT",
    "files": [
        "src/core",
        "src/runtime",
        "src/types.d.ts",
        "src/globals.d.ts",
        "dist"
    ],
    "bin": {
        "pure-dango": "src/index.ts"
    },
    "scripts": {
        "dev": "tsx src/index.ts",
        "prebuild": "node src/scripts/libs.cjs",
        "build": "node src/scripts/build.js",
        "build:lib": "esbuild src/core/tokenizer/tokenizer.ts --bundle=false --format=cjs --outfile=dist/lib/tokenizer.cjs --platform=node && esbuild src/core/parser/main.ts --bundle=false --format=cjs --outfile=dist/lib/main.cjs --platform=node"
    },
    "dependencies": {
        "gmp-wasm": "^1.3.2"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@yao-pkg/pkg": "^6.19.0",
        "archiver": "^7.0.1",
        "esbuild": "^0.28.0",
        "typescript": "^5.9.3"
    },
    "pkg": {
        "scripts": [
            "src/scripts/launcher.cjs"
        ],
        "assets": [
            "package.json",
            "node_modules/**/*",
            "src/index.ts",
            "src/core/**/*.ts",
            "src/runtime/**/*.js"
        ],
        "targets": [
            "node22-win-x64",
            "node22-macos-x64",
            "node22-macos-arm64",
            "node22-linux-x64",
            "node22-linux-arm64"
        ]
    },
    "main": "./dist/PureDango.cjs",
    "exports": {
        ".": "./dist/PureDango.cjs",
        "./src/core/tokenizer/tokenizer.js": "./dist/lib/tokenizer.cjs",
        "./src/core/parser/main.js": "./dist/lib/main.cjs"
    }
}
